


  import pandas as pd


df=pd.read_csv("raw_data.csv")


#Writing to the csv file


df2=df.copy()

df2=df2.drop_duplicates()
df2=df2.fillna(0)
df2=df2.sort_values("income")
df2=df2.reset_index(drop=True)

df2.to_csv("sorted_data.csv")  # Export the cleaned and sorted DataFrame to a CSV file and its creates another modified csv file 
                               # in this case "sorted_data.csv" is created


