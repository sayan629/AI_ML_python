


import numpy as np
import seaborn as sns
import pandas as pd


class KNNClassifier:
    def __init__(self,k=3):
        #step 1 : Initialize K
        self.k = k

    def _euclidean_dis(self, x1, x2):
        #step 2 : calculate distance using euclidean distance formula
        return np.sqrt(np.sum((x1-x2)**2))

    def fit(self, X, y): # store training data
        self.X_train =X
        self.y_train =y

    def _predict_one(self, x):
         #calculate distance from all training points
        distances = [self._euclidean_dis(x,x_train) for x_train in self.X_train]

        #step 3 : get indices of nearest K neighbors
        knn_indices = np.argsort(distances)[:self.k]  #nearest 3 values

        # get classes of nearest neighbors
        knn_classes = [self.y_train[i] for i in knn_indices]

        # step 4 : majority voting
        majority_class = np.argmax(np.bincount(knn_classes))
        return majority_class

    def predict(self,X):
        # predict for all test samples
        y_pred = [self._predict_one(x) for x in X]
        return np.array(y_pred)
        


#Data
X_train = np.array([
    [1, 2],
    [2, 3],
    [3, 3],
    [6, 5],
    [7, 7]
])

y_train = np.array([0, 0, 0, 1, 1])

X_test = np.array([
    [2, 2],
    [6, 6]
])

model = KNNClassifier()
model.fit(X_train , y_train)

y_pred = model.predict(X_test)
print(y_pred)


#Visualize
X_train_df = pd.DataFrame(X_train , columns = ["x1", "x2"])
X_train_df["label"] = y_train

sns.scatterplot(
    data = X_train_df,
    x = "x1",
    y = "x2",
    hue ="label"
)

X_test_df = pd.DataFrame (X_test , columns= ["x1","x2"])

sns.scatterplot(
    data = X_test_df,
    x = "x1",
    y = "x2",
    color = "black",
    marker = "X",
    label = "Test Points"

)
 


