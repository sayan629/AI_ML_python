# Remove Applicant_ID: Its given by Bank so it is not necessary to keep

df = df.drop("Applicant_ID",axis=1,errors="ignore")


df.head()
df.columns
df.info()





from sklearn.preprocessing import LabelEncoder , OneHotEncoder

# --- Label Encoding --- #
le = LabelEncoder()
df["Education_Level"] = le.fit_transform(df["Education_Level"])
df["Loan_Approved"] = le.fit_transform(df["Loan_Approved"])



df.head()


# --- one hot encoding --- #
cols = ["Employment_Status", 
        "Marital_Status", 
        "Loan_Purpose", 
        "Property_Area",
        "Gender",
        "Employer_Category"]

ohe = OneHotEncoder(drop="first",sparse_output=False,handle_unknown="ignore")
encoded = ohe.fit_transform(df[cols])


encoded


ohe.get_feature_names_out(cols)


# 2D array -> DataFrame
encoded_df = pd.DataFrame(encoded, columns = ohe.get_feature_names_out(cols), index=df.index)


encoded_df.head()


# Append the data with original Dataframe
# original columns are drop

df = pd.concat([df.drop(columns= cols), encoded_df],axis=1)


df.head()


df.describe()


df.info()





nums_cols = df.select_dtypes(include="number")
corr_matrix = nums_cols.corr()


corr_matrix



